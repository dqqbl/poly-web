# Polymarket 私钥（首次运行时用于生成 API 凭证，生成后可删除）
POLYMARKET_PRIVATE_KEY=0x你的私钥

# Polymarket 代理钱包地址（充值地址，可在 polymarket.com 账户页面找到）
POLYMARKET_PROXY_ADDRESS=0x你的代理钱包地址

# Builder 凭证（填写后 Claim 优先走 relayer gasless，无需自备 POL 付 gas）
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=

# 下单归因（可选）：配置后所有 CLOB 下单自动携带 builder_code
# 支持填写 32 字节 bytes32（0x + 64 hex）或 20 字节地址（会自动左填充）
POLY_BUILDER_CODE=
# 可选，不填默认使用 POLYMARKET_PROXY_ADDRESS
POLY_BUILDER_ADDRESS=

# 运行模式：full=带前端页面，headless=纯后端
APP_MODE=full

# 自动 Claim 开关
AUTO_CLAIM_ENABLED=true

# 自动策略配置（默认全关闭，服务每次启动都按这里的值初始化）
STRATEGY_S1_ENABLED=false
STRATEGY_S1_AMOUNT=1
STRATEGY_S2_ENABLED=false
STRATEGY_S2_AMOUNT=1
STRATEGY_S3_ENABLED=false
STRATEGY_S3_AMOUNT=1

# 自动策略默认滑点
ORDER_DEFAULT_SLIPPAGE=0.05
